{
  "name": "DWC Dev Container",
  "build": {
    "context": "../..",
    "dockerfile": "../../containers/dev/Dockerfile"
  },
  "overrideCommand": true,
  "remoteUser": "dev",
  "workspaceFolder": "/workspaces",
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "runArgs": [
    "--device=/dev/kvm",
    "--device=/dev/net/tun",
    "--cap-add=NET_ADMIN"
  ],
  "customizations": {
    "codespaces": {
      "openFiles": ["README.md"]
    },
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "ms-python.python",
        "ms-python.autopep8",
        "ms-vscode.cpptools"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.autoSave": "afterDelay"
      }
    }
  },
  "postCreateCommand": "bash -lc 'echo \"Dev Container Ready\" && node -v && python3 --version && docker --version || true'"
}
