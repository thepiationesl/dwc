#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$SCRIPT_DIR/helpers.sh"
. "$SCRIPT_DIR/config.sh"

showUsage() {
    cat << EOF
Usage: vm-setup [OPTIONS]

Setup Windows VM environment.

Options:
  -v, --version VERSION    Windows version (10, 11, ltsc) [default: 10]
  -l, --language LANG      Language (Chinese, English, Japanese) [default: Chinese]
  -c, --cpu CORES          CPU cores [default: 4]
  -r, --ram SIZE           RAM size [default: 8G]
  -d, --disk SIZE          Disk size [default: 64G]
  -s, --storage PATH       Storage directory [default: /storage]
  -C, --config FILE        Config file [default: ~/vm/vm.conf]
  -h, --help               Show this help message

Config file format (~/vm/vm.conf):
  VERSION=10
  LANGUAGE=Chinese
  CPU_CORES=4
  RAM_SIZE=8G
  DISK_SIZE=64G

Priority: CLI args > Environment > Config file > Defaults
EOF
}

parseArguments() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--version)
                export VERSION="${2:-}"
                shift 2
                ;;
            -l|--language)
                export LANGUAGE="${2:-}"
                shift 2
                ;;
            -c|--cpu)
                export CPU_CORES="${2:-}"
                shift 2
                ;;
            -r|--ram)
                export RAM_SIZE="${2:-}"
                shift 2
                ;;
            -d|--disk)
                export DISK_SIZE="${2:-}"
                shift 2
                ;;
            -s|--storage)
                export STORAGE="${2:-}"
                shift 2
                ;;
            -C|--config)
                export CONFIG_FILE="${2:-}"
                shift 2
                ;;
            -h|--help)
                showUsage
                exit 0
                ;;
            *)
                shift
                ;;
        esac
    done
}

parseArguments "$@"

initConfig
. "$SCRIPT_DIR/define.sh"
. "$SCRIPT_DIR/disk.sh"
. "$SCRIPT_DIR/install.sh"

STORAGE="${STORAGE:-$(getConfig STORAGE)}"
STORAGE="${STORAGE:-/storage}"

echo ""
echo "========================================"
echo "  Windows VM Setup"
echo "========================================"
echo ""

parseVersion
parseLanguage

echo "Configuration:"
echo "  VERSION:    $VERSION ($(printVersion "$VERSION"))"
echo "  LANGUAGE:   $(getLanguage "$LANGUAGE" "name")"
echo "  DISK_SIZE:  $DISK_SIZE"
echo "  RAM_SIZE:   $RAM_SIZE"
echo "  CPU_CORES:  $CPU_CORES"
echo "  STORAGE:    $STORAGE"
echo ""

if [ -f "$STORAGE/windows.boot" ] && [ -f "$STORAGE/windows.img" ]; then
    warn "Existing Windows installation detected!"
    echo ""
    read -p "Reinstall? [y/N]: " confirm
    if [[ "${confirm,,}" != "y"* ]]; then
        echo "Setup cancelled."
        exit 0
    fi
    rm -f "$STORAGE/windows.boot"
fi

echo ""
echo "Starting setup..."
echo ""

extractDrivers
detectCustom

if [ -z "$CUSTOM" ]; then
    lang=$(getLanguage "$LANGUAGE" "code")
    BOOT="$STORAGE/${VERSION}_${lang}.iso"
    
    if [ ! -f "$BOOT" ] || [ ! -s "$BOOT" ]; then
        info "Downloading Windows ISO..."
        downloadIso
    else
        info "Using existing ISO: $BOOT"
    fi
else
    BOOT="$CUSTOM"
    info "Using custom ISO: $BOOT"
fi

createDisk "$STORAGE/windows.img" "$DISK_SIZE" "qcow2"
setupEfi
touch "$STORAGE/windows.boot"

echo ""
echo "========================================"
echo "  Setup Complete!"
echo "========================================"
echo ""
echo "Files prepared:"
[ -f "$BOOT" ] && echo "  - ISO: $BOOT"
[ -f "$STORAGE/windows.img" ] && echo "  - Disk: $STORAGE/windows.img ($(getDiskInfo "$STORAGE/windows.img" | grep "virtual size" | cut -d: -f2 | xargs))"
[ -f "$STORAGE/windows.rom" ] && echo "  - UEFI: $STORAGE/windows.rom"
echo ""
echo "Run 'vm-start' to boot the virtual machine"
echo "VNC: localhost:5900 / WebSocket: localhost:5700"
echo ""
