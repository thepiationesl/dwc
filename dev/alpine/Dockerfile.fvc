# Alpine FVC - QEMU Windows 10 Container
# Style: dockur/windows compatible environment variables
# Base: alpine:edge | Target size: < 200MB

FROM alpine:edge

LABEL maintainer="DWC Project"
LABEL description="Alpine QEMU container for Windows 10 (dockur/windows style)"

# ============================================================
# Environment Variables (dockur/windows compatible)
# ============================================================
ENV VERSION="10" \
    LANGUAGE="Chinese" \
    DISK_SIZE="64G" \
    CPU_CORES="2" \
    RAM_SIZE="4G" \
    USERNAME="" \
    PASSWORD="" \
    # Network
    DHCP="Y" \
    # Virtualization flags
    VMX="N" \
    HV="Y" \
    KVM="Y" \
    # Extra QEMU arguments
    ARGUMENTS="" \
    # Paths
    STORAGE="/storage" \
    SHARED="/shared" \
    # Internal
    TZ="Asia/Shanghai" \
    LANG="C.UTF-8"

# ============================================================
# Configure Alpine mirrors
# ============================================================
RUN echo "http://mirrors.7.b.0.5.0.7.4.0.1.0.0.2.ip6.arpa/system/alpine/edge/main" > /etc/apk/repositories && \
    echo "http://mirrors.7.b.0.5.0.7.4.0.1.0.0.2.ip6.arpa/system/alpine/edge/community" >> /etc/apk/repositories

# ============================================================
# Install packages
# ============================================================
RUN apk add --no-cache \
    # QEMU
    qemu-system-x86_64 \
    qemu-img \
    qemu-hw-usb-host \
    # Networking
    iproute2 \
    iptables \
    dnsmasq \
    bridge-utils \
    # Web VNC (noVNC)
    novnc \
    py3-websockify \
    py3-numpy \
    # SMB sharing
    samba \
    # Utilities
    docker-cli \
    htop \
    bash \
    curl \
    wget \
    procps \
    # System
    ca-certificates \
    tzdata \
    tini

# ============================================================
# Clean up unnecessary QEMU firmware (reduce size)
# ============================================================
RUN cd /usr/share/qemu && \
    mkdir -p /tmp/qemu-keep && \
    # Keep essential firmware for Windows 10
    for f in bios-256k.bin efi-virtio.rom kvmvapic.bin vgabios-virtio.bin \
             vgabios-stdvga.bin linuxboot_dma.bin efi-e1000.rom efi-e1000e.rom \
             efi-pcnet.rom efi-rtl8139.rom; do \
        cp -f "$f" /tmp/qemu-keep/ 2>/dev/null || true; \
    done && \
    rm -rf /usr/share/qemu/* && \
    cp -f /tmp/qemu-keep/* /usr/share/qemu/ 2>/dev/null || true && \
    rm -rf /tmp/qemu-keep && \
    # Clean docs
    rm -rf /usr/share/doc/* /usr/share/man/* /usr/share/info/* /var/cache/apk/*

# ============================================================
# Create directories
# ============================================================
RUN mkdir -p /storage /shared /run/qemu /var/log/qemu /opt/scripts

# ============================================================
# TAP network setup script
# ============================================================
RUN cat > /opt/scripts/setup-network.sh << 'NETEOF'
#!/bin/bash
set -e

# Create TAP interface
if [ ! -c /dev/net/tun ]; then
    echo "[!] /dev/net/tun not found, TAP networking unavailable"
    exit 1
fi

# Setup TAP
ip tuntap add dev tap0 mode tap 2>/dev/null || true
ip link set tap0 up
ip addr add 172.20.0.1/24 dev tap0 2>/dev/null || true

# Enable IP forwarding
echo 1 > /proc/sys/net/ipv4/ip_forward

# Setup NAT
iptables -t nat -A POSTROUTING -s 172.20.0.0/24 -j MASQUERADE
iptables -A FORWARD -i tap0 -j ACCEPT
iptables -A FORWARD -o tap0 -j ACCEPT

# Start dnsmasq for DHCP
if [ "$DHCP" = "Y" ]; then
    dnsmasq --interface=tap0 \
            --bind-interfaces \
            --dhcp-range=172.20.0.100,172.20.0.200,12h \
            --dhcp-option=option:router,172.20.0.1 \
            --dhcp-option=option:dns-server,8.8.8.8,8.8.4.4 \
            --log-facility=/var/log/qemu/dnsmasq.log
fi

echo "[+] TAP network configured: tap0 (172.20.0.1/24)"
NETEOF
chmod +x /opt/scripts/setup-network.sh

# ============================================================
# SMB sharing setup script
# ============================================================
RUN cat > /opt/scripts/setup-smb.sh << 'SMBEOF'
#!/bin/bash

SMB_CONF="/etc/samba/smb.conf"

cat > "$SMB_CONF" << 'SMBCFG'
[global]
   workgroup = WORKGROUP
   server string = DWC Samba
   security = user
   map to guest = Bad User
   guest account = nobody

[shared]
   path = /shared
   browseable = yes
   writable = yes
   guest ok = yes
   create mask = 0777
   directory mask = 0777
   force user = nobody
   force group = nogroup
SMBCFG

# Start SMB if /shared is mounted
if mountpoint -q /shared 2>/dev/null || [ -d /shared ]; then
    smbd --foreground --no-process-group &
    echo "[+] SMB sharing enabled: //host/shared"
fi
SMBEOF
chmod +x /opt/scripts/setup-smb.sh

# ============================================================
# Main entrypoint script
# ============================================================
RUN cat > /opt/scripts/entrypoint.sh << 'ENTRYEOF'
#!/bin/bash
set -e

echo "=============================================="
echo "  DWC QEMU Windows Container"
echo "=============================================="
echo "  VERSION:    ${VERSION}"
echo "  CPU_CORES:  ${CPU_CORES}"
echo "  RAM_SIZE:   ${RAM_SIZE}"
echo "  DISK_SIZE:  ${DISK_SIZE}"
echo "=============================================="

# Setup TAP network
/opt/scripts/setup-network.sh || echo "[!] TAP network setup failed, using user mode"

# Setup SMB
/opt/scripts/setup-smb.sh &

# Create disk if not exists
DISK_FILE="${STORAGE}/windows.img"
if [ ! -f "$DISK_FILE" ]; then
    echo "[*] Creating disk: $DISK_FILE ($DISK_SIZE)"
    qemu-img create -f qcow2 "$DISK_FILE" "$DISK_SIZE"
fi

# Build CPU flags
CPU_FLAGS="host"
if [ "$KVM" = "Y" ]; then
    CPU_FLAGS="${CPU_FLAGS},kvm=on"
fi
if [ "$VMX" = "Y" ]; then
    CPU_FLAGS="${CPU_FLAGS},+vmx"
fi
if [ "$HV" = "N" ]; then
    CPU_FLAGS="${CPU_FLAGS},-hypervisor"
fi
CPU_FLAGS="${CPU_FLAGS},l3-cache=on,migratable=no"

# Check for extra arguments
if [ -n "$ARGUMENTS" ]; then
    # If ARGUMENTS contains -cpu, extract and merge
    if echo "$ARGUMENTS" | grep -q '\-cpu'; then
        EXTRA_CPU=$(echo "$ARGUMENTS" | grep -oP '(?<=-cpu )[^ ]+')
        CPU_FLAGS="${EXTRA_CPU}"
        ARGUMENTS=$(echo "$ARGUMENTS" | sed 's/-cpu [^ ]*//')
    fi
fi

# Determine network mode
if [ -c /dev/net/tun ] && ip link show tap0 &>/dev/null; then
    NET_ARGS="-netdev tap,id=net0,ifname=tap0,script=no,downscript=no"
    NET_ARGS="$NET_ARGS -device virtio-net-pci,netdev=net0,mac=02:4C:BB:C9:5B:42"
    echo "[+] Using TAP networking"
else
    NET_ARGS="-netdev user,id=net0,hostfwd=tcp::3389-:3389,hostfwd=udp::3389-:3389"
    NET_ARGS="$NET_ARGS -device virtio-net-pci,netdev=net0"
    echo "[+] Using User networking (NAT)"
fi

# UEFI firmware (if available)
UEFI_ARGS=""
if [ -f "${STORAGE}/OVMF_CODE.fd" ]; then
    if [ ! -f "${STORAGE}/OVMF_VARS.fd" ]; then
        cp /usr/share/OVMF/OVMF_VARS.fd "${STORAGE}/" 2>/dev/null || true
    fi
    if [ -f "${STORAGE}/OVMF_VARS.fd" ]; then
        UEFI_ARGS="-drive if=pflash,format=raw,readonly=on,file=${STORAGE}/OVMF_CODE.fd"
        UEFI_ARGS="$UEFI_ARGS -drive if=pflash,format=raw,file=${STORAGE}/OVMF_VARS.fd"
        echo "[+] UEFI boot enabled"
    fi
fi

# ISO detection
ISO_ARGS=""
for iso in "${STORAGE}"/*.iso; do
    if [ -f "$iso" ]; then
        ISO_ARGS="-cdrom $iso -boot d"
        echo "[+] Found ISO: $iso"
        break
    fi
done

# SMB device for sharing
SMB_ARGS=""
if [ -d /shared ] && [ "$(ls -A /shared 2>/dev/null)" ]; then
    SMB_ARGS="-device virtio-9p-pci,fsdev=shared,mount_tag=shared"
    SMB_ARGS="$SMB_ARGS -fsdev local,id=shared,path=/shared,security_model=mapped-xattr"
    echo "[+] 9P sharing enabled: /shared"
fi

# Start noVNC (Web interface on port 8006)
websockify --web=/usr/share/novnc 8006 localhost:5900 &
echo "[+] Web VNC: http://localhost:8006"

# Build final QEMU command
QEMU_CMD="qemu-system-x86_64 -nodefaults"
QEMU_CMD="$QEMU_CMD -cpu $CPU_FLAGS"
QEMU_CMD="$QEMU_CMD -smp $CPU_CORES,sockets=1,cores=$CPU_CORES,threads=1"
QEMU_CMD="$QEMU_CMD -m $RAM_SIZE"
QEMU_CMD="$QEMU_CMD -machine type=q35,smm=off,vmport=off,dump-guest-core=off,hpet=off,accel=kvm"
QEMU_CMD="$QEMU_CMD -enable-kvm"
QEMU_CMD="$QEMU_CMD -global kvm-pit.lost_tick_policy=discard"

# Display
QEMU_CMD="$QEMU_CMD -display vnc=:0,websocket=5700"
QEMU_CMD="$QEMU_CMD -vga virtio"

# Disk (virtio-scsi for performance)
QEMU_CMD="$QEMU_CMD -object iothread,id=io0"
QEMU_CMD="$QEMU_CMD -drive file=$DISK_FILE,id=drive0,format=qcow2,cache=none,aio=native,discard=on,detect-zeroes=on,if=none"
QEMU_CMD="$QEMU_CMD -device virtio-scsi-pci,id=scsi0,iothread=io0"
QEMU_CMD="$QEMU_CMD -device scsi-hd,drive=drive0,bus=scsi0.0,bootindex=1"

# USB
QEMU_CMD="$QEMU_CMD -device qemu-xhci,id=xhci"
QEMU_CMD="$QEMU_CMD -device usb-tablet"

# Network
QEMU_CMD="$QEMU_CMD $NET_ARGS"

# UEFI
QEMU_CMD="$QEMU_CMD $UEFI_ARGS"

# ISO
QEMU_CMD="$QEMU_CMD $ISO_ARGS"

# 9P Sharing
QEMU_CMD="$QEMU_CMD $SMB_ARGS"

# RTC
QEMU_CMD="$QEMU_CMD -rtc base=localtime"
QEMU_CMD="$QEMU_CMD -global ICH9-LPC.disable_s3=1"
QEMU_CMD="$QEMU_CMD -global ICH9-LPC.disable_s4=1"

# RNG
QEMU_CMD="$QEMU_CMD -object rng-random,id=rng0,filename=/dev/urandom"
QEMU_CMD="$QEMU_CMD -device virtio-rng-pci,rng=rng0"

# Extra arguments
if [ -n "$ARGUMENTS" ]; then
    QEMU_CMD="$QEMU_CMD $ARGUMENTS"
fi

# Monitor
QEMU_CMD="$QEMU_CMD -monitor telnet:localhost:7100,server,nowait,nodelay"

echo ""
echo "[*] Starting QEMU..."
echo "[*] VNC: localhost:5900 | WebSocket: localhost:5700"
echo "[*] Web: http://localhost:8006"
echo "[*] Monitor: telnet localhost 7100"
echo "[*] RDP: localhost:3389 (after Windows install)"
echo ""

# Execute QEMU (foreground)
exec $QEMU_CMD
ENTRYEOF
chmod +x /opt/scripts/entrypoint.sh

# ============================================================
# Volumes
# ============================================================
VOLUME ["/storage", "/shared"]

# ============================================================
# Ports
# ============================================================
# 8006 - Web VNC (noVNC)
# 5900 - VNC
# 5700 - VNC WebSocket
# 7100 - QEMU Monitor
# 3389 - RDP
EXPOSE 8006 5900 5700 7100 3389

# ============================================================
# Entrypoint
# ============================================================
WORKDIR /storage
ENTRYPOINT ["/sbin/tini", "--"]
CMD ["/opt/scripts/entrypoint.sh"]
