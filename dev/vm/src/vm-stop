#!/usr/bin/env bash
set -Eeuo pipefail

# Load modules
cd /run
. /run/helpers.sh
. /run/network.sh
. /run/samba.sh
. /run/power.sh

echo "======================================"
echo "  DWC Windows VM Stop"
echo "======================================"
echo ""

# Check if running
if [ ! -f "/run/shm/qemu.pid" ]; then
    info "VM is not running"
    exit 0
fi

local pid
pid=$(<"/run/shm/qemu.pid")

if ! isAlive "$pid"; then
    info "VM is not running (stale PID file)"
    rm -f "/run/shm/qemu.pid"
    exit 0
fi

# Stop gracefully
stopQemu

echo ""
echo "VM stopped."
