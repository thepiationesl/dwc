#!/usr/bin/env bash
set -Eeuo pipefail

# Load modules
cd /run
. /run/helpers.sh
. /run/define.sh
. /run/network.sh
. /run/disk.sh
. /run/install.sh
. /run/samba.sh
. /run/power.sh

STORAGE="/storage"
BOOT=""

echo "======================================"
echo "  DWC Windows VM Start"
echo "======================================"
echo ""

# Parse configuration
parseVersion
parseLanguage

# Check for disk
if [ ! -f "$STORAGE/windows.img" ]; then
    error "No disk image found!"
    error "Run 'vm-setup' first to prepare the installation."
    exit 1
fi

# Find boot ISO
detectCustom
if [ -n "$CUSTOM" ]; then
    BOOT="$CUSTOM"
else
    local lang
    lang=$(getLanguage "$LANGUAGE" "code")
    local iso="$STORAGE/${VERSION}_${lang}.iso"
    [ -f "$iso" ] && BOOT="$iso"
fi

# Check if already running
if [ -f "/run/shm/qemu.pid" ]; then
    local pid
    pid=$(<"/run/shm/qemu.pid")
    if isAlive "$pid"; then
        error "VM is already running (PID: $pid)"
        error "Run 'vm-stop' to stop it first."
        exit 1
    fi
fi

echo "Configuration:"
echo "  VERSION:    $(printVersion "$VERSION")"
echo "  CPU_CORES:  $CPU_CORES"
echo "  RAM_SIZE:   $RAM_SIZE"
echo "  DISK:       $STORAGE/windows.img"
[ -n "$BOOT" ] && echo "  ISO:        $BOOT"
echo ""

# Setup network
configureNetwork

# Start Samba
startSamba

# Start QEMU
export BOOT
runQemu

echo ""
echo "======================================"
echo "  VM Started Successfully"
echo "======================================"
echo ""
echo "Access:"
echo "  VNC:       :0 (localhost:5900)"
echo "  WebSocket: localhost:5700"
echo "  RDP:       localhost:3389 (after install)"
echo "  Samba:     \\\\172.20.0.1\\shared"
echo ""
echo "Control:"
echo "  vm-stop    - Stop VM gracefully"
echo "  vm-status  - Show VM status"
echo ""
echo "Press Ctrl+C to detach (VM will keep running)"
echo ""

# Wait for QEMU (in foreground mode)
if [[ "${1:-}" != "-d" ]] && [[ "${1:-}" != "--daemon" ]]; then
    waitForQemu
fi
